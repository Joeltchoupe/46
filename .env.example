# ============================================================
# W46 — Environment Configuration
# ============================================================

# ---------- Core ----------
W46_ENV=development
# development | staging | production
W46_SECRET_KEY=change-me-to-64-hex-chars-in-production
W46_API_HOST=0.0.0.0
W46_API_PORT=8046
W46_LOG_LEVEL=INFO

# ---------- PostgreSQL ----------
W46_DB_HOST=postgres
W46_DB_PORT=5432
W46_DB_NAME=w46
W46_DB_USER=w46
W46_DB_PASSWORD=change-me
W46_DB_POOL_MIN=5
W46_DB_POOL_MAX=20

# ---------- Redis (circuit breakers, rate limiting, caching) ----------
W46_REDIS_URL=redis://redis:6379/0

# ---------- KMS ----------
# Provider: local | gcp | fireblocks
W46_KMS_PROVIDER=local

# Local KMS (dev/test only)
W46_KMS_LOCAL_DIR=./data/keys
W46_KMS_LOCAL_PASSPHRASE=dev-passphrase-change-me

# GCP KMS (staging/production)
W46_GCP_PROJECT_ID=
W46_GCP_LOCATION=global
W46_GCP_KEYRING=w46-keyring
W46_GCP_KEY_ID=w46-master-key
# Path to service account JSON or use workload identity
GOOGLE_APPLICATION_CREDENTIALS=

# Fireblocks MPC (production final)
W46_FIREBLOCKS_API_KEY=
W46_FIREBLOCKS_API_SECRET_PATH=
W46_FIREBLOCKS_BASE_URL=https://api.fireblocks.io

# ---------- Blockchain — Solana ----------
W46_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
W46_SOLANA_RPC_URL_FALLBACK=https://solana-mainnet.g.alchemy.com/v2/YOUR_KEY
W46_SOLANA_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
W46_SOLANA_COMMITMENT=confirmed
W46_SOLANA_MICRO_PAYMENT_THRESHOLD_USDC=50

# ---------- Blockchain — Base (L2) ----------
W46_BASE_RPC_URL=https://mainnet.base.org
W46_BASE_RPC_URL_FALLBACK=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
W46_BASE_CHAIN_ID=8453
W46_BASE_USDC_CONTRACT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
W46_BASE_COMMITMENT_REGISTRY=0x0000000000000000000000000000000000000000
W46_BASE_GAS_PRICE_GWEI=0.01

# ---------- Routing ----------
W46_ROUTING_SOLANA_MAX_USDC=50
W46_ROUTING_BASE_MIN_USDC=500
W46_ROUTING_CIRCUIT_BREAKER_THRESHOLD=5
W46_ROUTING_CIRCUIT_BREAKER_TIMEOUT_SEC=300

# ---------- Fees ----------
W46_FEE_SOLANA_PER_USDC=0.005
W46_FEE_BASE_PER_USDC=0.05
W46_FEE_INTERNAL_PER_USDC=0.0
W46_FEE_SWEEP_INTERVAL_SEC=3600

# ---------- Operator Wallets (fee collection) ----------
W46_OPERATOR_SOLANA_ADDRESS=
W46_OPERATOR_BASE_ADDRESS=

# ---------- Policy Defaults ----------
W46_POLICY_DEFAULT_MAX_PER_TX=1000
W46_POLICY_DEFAULT_DAILY_LIMIT=10000
W46_POLICY_DEFAULT_MONTHLY_LIMIT=100000
W46_POLICY_DEFAULT_HUMAN_APPROVAL_THRESHOLD=5000
W46_POLICY_DEFAULT_VERIFIED_RAIL_THRESHOLD=500

# ---------- Anchoring ----------
W46_ANCHOR_BATCH_SIZE=100
W46_ANCHOR_SOLANA_INTERVAL_SEC=600
W46_ANCHOR_BASE_INTERVAL_SEC=600

# ---------- Reconciliation ----------
W46_RECONCILIATION_INTERVAL_SEC=300
W46_RECONCILIATION_ALERT_WEBHOOK=

# ---------- Auth ----------
W46_API_KEY_HASH_ITERATIONS=100000
W46_SESSION_TTL_SEC=86400
W46_RATE_LIMIT_PER_MINUTE=120

# ---------- Email / Verification ----------
W46_SMTP_HOST=
W46_SMTP_PORT=587
W46_SMTP_USER=
W46_SMTP_PASSWORD=
W46_SMTP_FROM=noreply@w46.io
W46_VERIFICATION_TOKEN_TTL_SEC=3600

# ---------- CORS ----------
W46_CORS_ORIGINS=["http://localhost:3000"]
